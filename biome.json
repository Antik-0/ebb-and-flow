{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": [
      "apps/**/*",
      "docs/**/*",
      "packages/**/*",
      "scripts/*",
      "uno.config.ts",
      "oxfmt.config.ts",
      "drizzle.config.ts",
      "package.json",
      "tsconfig.json",
      "!**/node_modules",
      "!**/dist",
      "!**/.db",
      "!**/.drizzle",
      "!**/.nuxt",
      "!**/.next",
      "!**/.nitro",
      "!**/.output",
      "!**/out"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noStaticElementInteractions": "off",
        "noSvgWithoutTitle": "off",
        "useKeyWithClickEvents": "off",
        "useValidAnchor": "off"
      },
      "correctness": {
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        },
        "useExhaustiveDependencies": "off"
      },
      "performance": {
        "noImgElement": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": {
          "level": "warn",
          "options": {
            "style": "separatedType"
          }
        },
        "useNumberNamespace": {
          "level": "warn",
          "fix": "safe"
        },
        "useNumericSeparators": "warn",
        "useSelfClosingElements": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "ignoreHtmlElements": true
          }
        },
        "useTemplate": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "off",
        "noExplicitAny": "off",
        "noUnknownAtRules": {
          "level": "warn",
          "options": {
            "ignore": ["unocss"]
          }
        }
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "attributes": ["class", "className"],
            "functions": ["clsx"]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "off",
        "useSortedAttributes": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.vue"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          },
          "nursery": {
            "useVueDefineMacrosOrder": {
              "level": "error",
              "fix": "safe",
              "options": {
                "order": [
                  "defineProps",
                  "defineModel",
                  "defineEmits",
                  "defineSlots"
                ]
              }
            },
            "useVueNextTickPromise": "error",
            "noVueVIfWithVFor": "error",
            "useVueHyphenatedAttributes": "error",
            "useVueVForKey": "error",
            "useVueValidVElse": "error",
            "useVueValidVElseIf": "error",
            "useVueValidVFor": "error"
          }
        }
      }
    }
  ]
}
