{
  "name": "ebb-and-flow",
  "version": "2.0.0",
  "description": "潮起潮落的个人博客",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "boot": "bun install && bun stub",
    "build": "turbo run build --filter=docs",
    "clean": "bun run ./scripts/cleanup.ts",
    "compress": "bun run ./scripts/compress.ts",
    "dev": "turbo run dev --filter=docs",
    "dev:next": "turbo run dev --filter=docs-next",
    "ebb-docs": "bun run --elide-lines 0 --filter ebb-docs source",
    "lint": "biome check --fix && bun run eslint",
    "lint:debug": "bunx @eslint/config-inspector@latest",
    "preview": "turbo run preview --filter=docs",
    "stub": "turbo run stub",
    "up-deps": "bun run ./scripts/upgrade.ts"
  },
  "lint-staged": {
    "*.{ts,vue,json}": ["bun biome check --fix"]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@config/eslint": "workspace:*",
    "@config/tsconfig": "workspace:*",
    "@config/unocss": "workspace:*",
    "@types/bun": "^1.3.10",
    "eslint": "catalog:",
    "lint-staged": "^16.3.4",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "turbo": "^2.8.17",
    "unbuild": "^3.6.1",
    "unocss": "catalog:"
  },
  "workspaces": {
    "packages": ["docs", "apps/*", "packages/*", "packages/configs/*"],
    "catalog": {
      "@unocss/nuxt": "^66.6.6",
      "@unocss/postcss": "^66.6.6",
      "@unocss/reset": "^66.6.6",
      "eslint": "^10.0.3",
      "iconify-icon": "^3.0.2",
      "motion": "^12.36.0",
      "motion-v": "^2.0.0",
      "next": "^16.1.6",
      "nuxt": "^4.4.2",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "typescript": "^5.9.3",
      "unocss": "^66.6.6",
      "vue": "^3.5.30"
    }
  }
}
