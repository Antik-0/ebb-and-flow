{
  "name": "ebb-and-flow",
  "private": true,
  "description": "潮起潮落的个人博客",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/configs/*"
    ],
    "catalog": {
      "@unocss/nuxt": "^66.7.5",
      "@unocss/postcss": "^66.7.5",
      "@unocss/reset": "^66.7.5",
      "iconify-icon": "^3.0.2",
      "motion": "^12.42.2",
      "motion-v": "^2.3.0",
      "next": "^16.2.10",
      "nuxt": "^4.4.8",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "typescript": "6.0.3",
      "unocss": "^66.7.5",
      "vue": "^3.5.39"
    }
  },
  "type": "module",
  "scripts": {
    "boot": "bun install && bun db:sync",
    "build": "bun run ./scripts/ebb-build.ts",
    "build:next": "turbo run ebb-next#build",
    "build:nuxt": "turbo run ebb-nuxt#build",
    "check": "oxfmt && biome check --fix",
    "clean": "bun run ./scripts/cleanup.ts",
    "compress": "bun run ./scripts/compress.ts",
    "db:push": "bunx drizzle-kit push",
    "db:start": "turbo run ebb-server#start",
    "db:sync": "turbo run ebb-server#sync",
    "dev": "turbo run ebb-nuxt#dev",
    "dev:next": "turbo run ebb-next#dev",
    "image-kit": "bun run ./scripts/image-kit.ts",
    "up-deps": "bun run ./scripts/upgrade.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@config/tsconfig": "workspace:*",
    "@config/unocss": "workspace:*",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "1.0.0-rc.4",
    "lint-staged": "^17.0.8",
    "ora": "^9.4.1",
    "oxfmt": "^0.58.0",
    "picocolors": "^1.1.1",
    "turbo": "^2.10.4",
    "typescript": "catalog:",
    "unocss": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,css,vue,json}": [
      "bun run check"
    ]
  },
  "packageManager": "bun@1.3.14"
}
