{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "with": ["ebb-server#start"]
    },
    "start": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "sync": {
      "dependsOn": [],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".output/**"]
    }
  },
  "cacheDir": ".turbo/cache"
}
